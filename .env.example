# Copy to .env.local for development. Never commit a filled-in .env.local —
# it's already gitignored. See docs/architecture/stage-1-assessment.md §12 for
# why this project currently targets a single shared Supabase project rather
# than fully separate dev/staging/production projects.

# demo | staging | production. Defaults to "demo" if unset or unrecognised
# (fail closed - see src/lib/env.ts). Only "demo" shows the demo-data banner;
# only "production" enables the startup readiness check in
# src/instrumentation.ts.
NEXT_PUBLIC_APP_MODE=demo

# Supabase project settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only secret (Supabase project settings > API > service_role key).
# Bypasses Row Level Security - never expose this to the browser, never
# prefix it with NEXT_PUBLIC_. Required for login rate-limiting and audit
# logging to function; without it, sign-in will fail even with correct
# credentials.
SUPABASE_SERVICE_ROLE_KEY=changeme

# Used to build the password-reset redirect link. Set to the real deployed
# origin in staging/production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
